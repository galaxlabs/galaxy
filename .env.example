# Galaxy — Environment Configuration
# Copy to .env and fill in your values.
# Site configs in sites/ take precedence over env vars.

# Database connection
GALAXY_DB_TYPE=postgres
GALAXY_DB_HOST=127.0.0.1
GALAXY_DB_PORT=5432
GALAXY_DB_NAME=galaxy_default
GALAXY_DB_USER=galaxy_default_user
GALAXY_DB_PASSWORD=password

# Server
GALAXY_SERVER_PORT=8080
GALAXY_DEV_MODE=true

# Default admin credentials (used at install time)
GALAXY_ADMIN_USER=Administrator
GALAXY_ADMIN_PASSWORD=admin
GALAXY_ADMIN_EMAIL=administrator@galaxy.local
